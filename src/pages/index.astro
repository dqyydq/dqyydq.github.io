---
import { getCollection } from "astro:content";
import ArticleList from "../components/ArticleList.astro";
import ProjectList from "../components/ProjectList.astro";
import { projects } from "../data/projects";
import BaseLayout from "../layouts/BaseLayout.astro";

const notes = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestNote = notes[0];
const recentNotes = notes.slice(0, 3);
const formattedDate = new Intl.DateTimeFormat("zh-CN", { year: "numeric", month: "long", day: "numeric" }).format(latestNote.data.pubDate);
---

<BaseLayout>
  <section class="manuscript-shell" aria-label="首页介绍">
    <div class="manuscript-book" data-book>
      <div class="book-cover" aria-hidden="true">
        <span>邓权耀</span>
        <small>学习笔记与项目记录</small>
      </div>
      <div class="book-spread">
        <article class="book-page book-page-left">
          <p class="folio">主页 · 001</p>
          <p class="ink-label">你好，我是邓权耀</p>
          <h1>把学到的东西，<br />慢慢写下来。</h1>
          <p class="book-lead">我是一名电子信息软件方向的研究生。这里放学习笔记、源码阅读和项目记录，尽量把正在理解的问题写清楚。</p>
          <div class="margin-note note-left">不是答案集，<br />是过程记录。</div>
          <div class="book-now">
            <span>最近在做</span>
            <p>学习 Agent 系统的工程化实现，也在用 Docker、PostgreSQL 和 FastAPI 搭一个能持续迭代的小实验环境。</p>
            <a href="/blog">从最新笔记开始 <span aria-hidden="true">→</span></a>
          </div>
        </article>
        <article class="book-page book-page-right">
          <p class="folio">最新笔记 · 002</p>
          <div class="note-header">
            <span>{latestNote.data.type}</span>
            <time datetime={latestNote.data.pubDate.toISOString()}>{formattedDate}</time>
          </div>
          <h2><a href={`/blog/${latestNote.id}/`}>{latestNote.data.title}</a></h2>
          <p class="note-summary">{latestNote.data.description}</p>
          <div class="code-slip" aria-label="学习摘录">
            <span>compose.yaml</span>
            <code>healthcheck: pg_isready</code>
            <code>container ≠ service ready</code>
          </div>
          <div class="margin-note note-right">启动成功<br />不等于可用。</div>
          <div class="note-tags">{latestNote.data.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}</div>
          <a class="read-note" href={`/blog/${latestNote.id}/`}>翻到这篇笔记 <span aria-hidden="true">→</span></a>
        </article>
      </div>
    </div>
  </section>

  <section class="section home-section">
    <div class="section-heading"><div class="section-label">项目记录</div><a class="text-link" href="/projects">全部项目 →</a></div>
    <ProjectList items={projects.slice(0, 3)} />
  </section>

  <section class="section home-section">
    <div class="section-heading"><div class="section-label">最近更新</div><a class="text-link" href="/blog">全部笔记 →</a></div>
    <ArticleList entries={recentNotes} />
  </section>
</BaseLayout>

<script>
  const book = document.querySelector<HTMLElement>("[data-book]");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const storageKey = "dqy-manuscript-opened";

  if (book) {
    const seen = sessionStorage.getItem(storageKey) === "true";
    if (reduceMotion || seen) {
      book.classList.add("is-open");
    } else {
      requestAnimationFrame(() => book.classList.add("is-opening"));
      window.setTimeout(() => {
        book.classList.remove("is-opening");
        book.classList.add("is-open");
        sessionStorage.setItem(storageKey, "true");
      }, 900);
    }
  }
</script>
